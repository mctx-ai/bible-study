{
  "name": "bible",
  "version": "1.0.7",
  "description": "Deep Bible study for MCP-compatible AI clients. 155,510 verses across 5 public domain translations (KJV, WEB, ASV, YLT, Darby). Semantic search via 155K+ vector embeddings. 606,140 cross-references. 17,543 Strong's concordance entries with Hebrew and Greek lexicon definitions. 447,734 morphology records for original-language word studies. 5,319 Nave's Topical Bible categories. Full-text search via FTS5. Every verse response includes a structured citation.",
  "homepage": "https://github.com/mctx-ai/bible-mcp-server",
  "repository": {
    "type": "git",
    "url": "https://github.com/mctx-ai/bible-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/mctx-ai/bible-mcp-server/issues"
  },
  "keywords": [
    "bible",
    "scripture",
    "mcp",
    "mcp-server",
    "kjv",
    "strongs",
    "concordance",
    "word-study",
    "cross-references",
    "theology",
    "bible-study",
    "hebrew",
    "greek",
    "naves",
    "darby",
    "translations"
  ],
  "author": "mctx-ai",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --minify --platform=node --format=esm --outfile=dist/index.js",
    "db:schema": "tsx scripts/create-schema.ts",
    "dev": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:@mctx-ai/mcp-server --sourcemap && run-p dev:build dev:server",
    "dev:build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:@mctx-ai/mcp-server --watch --sourcemap",
    "dev:server": "mctx-dev dist/index.js",
    "test": "vitest run",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "data:acquire": "tsx scripts/acquire-data.ts",
    "etl:bible": "tsx scripts/etl-bible-text.ts",
    "etl:morphology": "tsx scripts/etl-morphology.ts",
    "etl:crossrefs": "tsx scripts/etl-crossrefs.ts",
    "etl:naves": "tsx scripts/etl-naves.ts",
    "etl:strongs": "tsx scripts/etl-strongs.ts",
    "search:fts5": "tsx scripts/populate-fts5.ts",
    "search:embeddings": "tsx scripts/ingest-embeddings.ts",
    "data:validate": "tsx scripts/validate.ts",
    "setup:infra": "bash scripts/setup-infra.sh"
  },
  "dependencies": {
    "@mctx-ai/mcp-server": "0.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@mctx-ai/mcp-dev": "^0.5.8",
    "@types/node": "^25.3.5",
    "esbuild": "^0.27.3",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.1.8",
    "npm-run-all2": "^7.0.2",
    "prettier": "^3.8.1",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "license": "MIT"
}
