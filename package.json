{
  "name": "bible",
  "version": "1.3.3",
  "description": "Find verses, trace words to Hebrew or Greek roots, and follow cross-references in one conversation. Access 155,510 verses across five complete translations (KJV, WEB, ASV, YLT, Darby) without switching tabs. Look up any word in its Hebrew or Greek original, read the BDB or Thayer lexicon definition, and trace every occurrence across the canon. Follow 606,140 cross-references to find how scripture interprets scripture. Research any subject through Nave's Topical Bible, with 5,319 curated categories organized by theme, person, and topic. Run full-text keyword searches from Genesis to Revelation, or describe a concept in plain language and get semantically matched passages ranked by meaning. With 17,543 Strong's concordance entries and morphology records for 447,734 words, the scholarly depth that once required specialized desktop software is now available through natural conversation.",
  "homepage": "https://github.com/mctx-ai/bible-mcp-server",
  "repository": {
    "type": "git",
    "url": "https://github.com/mctx-ai/bible-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/mctx-ai/bible-mcp-server/issues"
  },
  "keywords": [
    "bible",
    "scripture",
    "mcp",
    "mcp-server",
    "kjv",
    "strongs",
    "concordance",
    "word-study",
    "cross-references",
    "theology",
    "bible-study",
    "hebrew",
    "greek",
    "naves",
    "darby",
    "translations"
  ],
  "author": "mctx-ai",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --minify --platform=neutral --target=es2020 --format=esm --outfile=dist/index.js",
    "db:schema": "tsx scripts/create-schema.ts",
    "dev": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:@mctx-ai/mcp-server --sourcemap && run-p dev:build dev:server",
    "dev:build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:@mctx-ai/mcp-server --watch --sourcemap",
    "dev:server": "mctx-dev dist/index.js",
    "test": "vitest run",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "data:acquire": "tsx scripts/acquire-data.ts",
    "etl:bible": "tsx scripts/etl-bible-text.ts",
    "etl:morphology": "tsx scripts/etl-morphology.ts",
    "etl:crossrefs": "tsx scripts/etl-crossrefs.ts",
    "etl:naves": "tsx scripts/etl-naves.ts",
    "etl:strongs": "tsx scripts/etl-strongs.ts",
    "search:fts5": "tsx scripts/populate-fts5.ts",
    "search:embeddings": "tsx scripts/ingest-embeddings.ts",
    "data:validate": "tsx scripts/validate.ts",
    "setup:infra": "bash scripts/setup-infra.sh",
    "typecheck": "tsc --noEmit && tsc --noEmit --project tsconfig.scripts.json"
  },
  "dependencies": {
    "@mctx-ai/mcp-server": "^1.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@mctx-ai/mcp-dev": "^1.1.0",
    "@types/node": "^25.3.5",
    "esbuild": "^0.27.3",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.1.8",
    "npm-run-all2": "^7.0.2",
    "prettier": "^3.8.1",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "license": "MIT"
}
